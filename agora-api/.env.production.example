NODE_ENV=production
PORT=8080
CORS_ALLOWED_ORIGINS=https://agora.example.com,https://app.agora.example.com

DB_HOST=postgres
DB_PORT=5432
DB_NAME=agora
DB_USER=agora_user
DB_PASSWORD=change_me_strong
DB_SSL=false
DB_CREDENTIALS_SECRET_JSON=
DB_CREDENTIALS_SECRET_BASE64=

JWT_ACCESS_SECRET=replace_with_64_plus_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_64_plus_chars
JWT_REFRESH_EXPIRES_IN=30d

INTERNAL_API_KEY=replace_with_internal_service_key
ATTENDANCE_DEVICE_API_KEY=replace_with_device_ingest_key
ATTENDANCE_DEVICE_LATE_AFTER_LOCAL_TIME=08:05:00
ATTENDANCE_DEVICE_NOTIFICATION_CHANNEL=push
RATE_LIMIT_AUTH_LOGIN_WINDOW_MS=60000
RATE_LIMIT_AUTH_LOGIN_MAX=15
RATE_LIMIT_DEVICE_INGEST_WINDOW_MS=60000
RATE_LIMIT_DEVICE_INGEST_MAX=180
RATE_LIMIT_INTERNAL_WINDOW_MS=60000
RATE_LIMIT_INTERNAL_MAX=240

NOTIFICATION_WORKER_INTERVAL_MS=5000
NOTIFICATION_WORKER_BATCH_SIZE=20
NOTIFICATION_WORKER_MAX_RETRIES=3
NOTIFICATION_WORKER_BASE_BACKOFF_SECONDS=30
NOTIFICATION_WORKER_MAX_BACKOFF_SECONDS=1800

PUSH_PROVIDER=fcm
PUSH_WEBHOOK_URL=
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
FCM_TOKEN_URI=https://oauth2.googleapis.com/token
FCM_SCOPE=https://www.googleapis.com/auth/firebase.messaging

EMAIL_PROVIDER=mock
EMAIL_WEBHOOK_URL=
SMS_PROVIDER=mock
SMS_WEBHOOK_URL=

REMINDER_WORKER_INTERVAL_MS=300000
REMINDER_WORKER_RUN_ONCE=false
REMINDER_HOMEWORK_DUE_ENABLED=true
REMINDER_HOMEWORK_DUE_WITHIN_HOURS=24
REMINDER_ATTENDANCE_ABSENT_ENABLED=true
REMINDER_FEE_OVERDUE_ENABLED=true

SLO_AVAILABILITY_TARGET_PERCENT=99.95
SLO_SHORT_WINDOW_MINUTES=5
SLO_LONG_WINDOW_MINUTES=60
SLO_BURN_RATE_WARNING=2
SLO_BURN_RATE_CRITICAL=4

ALERT_WORKER_QUEUE_DEPTH_WARNING=200
ALERT_WORKER_QUEUE_DEPTH_CRITICAL=1000
ALERT_WORKER_OLDEST_QUEUED_MINUTES_WARNING=10
ALERT_WORKER_OLDEST_QUEUED_MINUTES_CRITICAL=30
ALERT_WORKER_FAILED_PENDING_WARNING=50
ALERT_WORKER_FAILED_PENDING_CRITICAL=250
WORKER_METRICS_PUBLISH_ENABLED=true
WORKER_METRICS_PUBLISH_INTERVAL_MS=60000
WORKER_METRICS_PUBLISH_RUN_ONCE=false
WORKER_METRICS_NAMESPACE=Agora/Workers
WORKER_METRICS_SERVICE_DIMENSION=agora-api
WORKER_METRICS_AWS_REGION=us-east-1

STORAGE_PROVIDER=s3
STORAGE_BUCKET=agora-prod
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=
STORAGE_FORCE_PATH_STYLE=false
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_SIGNED_URL_EXPIRES_IN=900
STORAGE_MAX_UPLOAD_BYTES=15728640
STORAGE_PUBLIC_BASE_URL=
STORAGE_LOCAL_BASE_DIR=/tmp/agora-storage
STORAGE_LOCAL_SIGNING_SECRET=replace_with_storage_signing_secret

GCS_PROJECT_ID=
GCS_KEY_FILENAME=
GCS_CLIENT_EMAIL=
GCS_PRIVATE_KEY=
